[Unit]
Description=Shelly iroh relay fallback service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ shelly_relay_user }}
Group={{ shelly_relay_group }}
WorkingDirectory={{ shelly_relay_data_dir }}
Environment=SHELLY_RELAY_MODE=iroh-relay
Environment=SHELLY_IROH_RELAY_HTTP_ADDR={{ shelly_iroh_relay_http_addr }}
Environment=SHELLY_IROH_RELAY_HTTPS_ADDR={{ shelly_iroh_relay_https_addr }}
Environment=SHELLY_IROH_RELAY_QUIC_ADDR={{ shelly_iroh_relay_quic_addr }}
Environment=SHELLY_IROH_RELAY_METRICS_ADDR={{ shelly_iroh_relay_metrics_addr }}
Environment=SHELLY_IROH_RELAY_CERT_DIR={{ shelly_iroh_relay_cert_dir }}
Environment=SHELLY_IROH_RELAY_HOSTNAME={{ shelly_iroh_relay_hostname }}
Environment=SHELLY_IROH_RELAY_CONTACT_EMAIL={{ shelly_iroh_relay_contact_email }}
Environment=SHELLY_IROH_RELAY_STAGING={{ shelly_iroh_relay_staging }}
Environment=SHELLY_IROH_RELAY_HTTP_ONLY={{ shelly_iroh_relay_http_only }}
ExecStart={{ shelly_relay_bin_dir }}/shelly-relay
Restart=on-failure
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={{ shelly_relay_data_dir }}

[Install]
WantedBy=multi-user.target
