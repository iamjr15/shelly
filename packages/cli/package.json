{
  "name": "shellykit",
  "version": "1.0.0",
  "description": "Your terminal sessions, from anywhere.",
  "bin": {
    "shelly": "bin/shelly",
    "shellyd": "bin/shellyd"
  },
  "scripts": {
    "postinstall": "node install.js"
  },
  "optionalDependencies": {
    "shellykit-darwin-arm64": "1.0.0",
    "shellykit-darwin-x64": "1.0.0",
    "shellykit-linux-arm64": "1.0.0",
    "shellykit-linux-x64": "1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/shelly",
    "bin/shellyd",
    "install.js",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamjr15/shelly.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "terminal",
    "mobile",
    "pty",
    "tmux",
    "mosh",
    "claude-code",
    "codex",
    "coding-agent"
  ],
  "preferUnplugged": true
}
