#!/usr/bin/env bash
set -euo pipefail

android_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
gradle_version="8.14.3"
gradle_sha256="bd71102213493060956ec229d946beee57158dbd89d0e62b91bca0fa2c5f3531"
cache_root="${SHELLY_GRADLE_CACHE:-${XDG_CACHE_HOME:-$HOME/.cache}/shelly/gradle}"
gradle_dir="$cache_root/gradle-$gradle_version"
gradle_zip="$cache_root/gradle-$gradle_version-bin.zip"
gradle_url="https://services.gradle.org/distributions/gradle-$gradle_version-bin.zip"

if [[ "$(uname -s)" == "Darwin" ]]; then
  for locale_var in LANG LC_ALL LC_CTYPE; do
    if [[ "${!locale_var:-}" == "C.UTF-8" ]]; then
      export "$locale_var=en_US.UTF-8"
    fi
  done
fi

java_major_version() {
  local java_home="$1"
  local version major
  if [[ -z "$java_home" || ! -x "$java_home/bin/java" ]]; then
    return 1
  fi
  version="$("$java_home/bin/java" -version 2>&1 | awk -F '"' '/version/ { print $2; exit }')"
  if [[ -z "$version" ]]; then
    return 1
  fi
  major="${version%%.*}"
  if [[ "$major" == "1" ]]; then
    version="${version#*.}"
    major="${version%%.*}"
  fi
  [[ "$major" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$major"
}

android_studio_jbr="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
if [[ -d "$android_studio_jbr" ]]; then
  current_java_major="$(java_major_version "${JAVA_HOME:-}" || true)"
  if [[ -z "${JAVA_HOME:-}" || -z "$current_java_major" || "$current_java_major" -lt 21 ]]; then
    export JAVA_HOME="$android_studio_jbr"
  fi
fi

if [[ -z "${ANDROID_HOME:-}" ]]; then
  if [[ -d "$HOME/Library/Android/sdk" ]]; then
    export ANDROID_HOME="$HOME/Library/Android/sdk"
  elif [[ -d "$HOME/Android/Sdk" ]]; then
    export ANDROID_HOME="$HOME/Android/Sdk"
  fi
fi

if [[ -z "${JAVA_HOME:-}" || ! -x "$JAVA_HOME/bin/java" ]]; then
  echo "JAVA_HOME is not set. Install JDK 21+ or Android Studio, then retry." >&2
  exit 1
fi

java_major="$(java_major_version "$JAVA_HOME" || true)"
if [[ -z "$java_major" || "$java_major" -lt 21 ]]; then
  echo "JAVA_HOME must point to JDK 21+ for Android SDK 36 Robolectric tests. Install JDK 21+ or Android Studio, then retry." >&2
  exit 1
fi

if [[ -z "${ANDROID_HOME:-}" || ! -d "$ANDROID_HOME" ]]; then
  echo "ANDROID_HOME is not set. Install the Android SDK or set ANDROID_HOME, then retry." >&2
  exit 1
fi

if [[ ! -x "$gradle_dir/bin/gradle" ]]; then
  mkdir -p "$cache_root"
  if [[ ! -f "$gradle_zip" ]]; then
    curl -fL "$gradle_url" -o "$gradle_zip"
  fi

  actual_sha256="$(shasum -a 256 "$gradle_zip" | awk '{print $1}')"
  if [[ "$actual_sha256" != "$gradle_sha256" ]]; then
    rm -f "$gradle_zip"
    echo "Gradle distribution checksum mismatch for $gradle_zip" >&2
    echo "expected: $gradle_sha256" >&2
    echo "actual:   $actual_sha256" >&2
    exit 1
  fi

  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "$tmp_dir"' EXIT
  unzip -q "$gradle_zip" -d "$tmp_dir"
  rm -rf "$gradle_dir"
  mv "$tmp_dir/gradle-$gradle_version" "$gradle_dir"
fi

cd "$android_root"
exec "$gradle_dir/bin/gradle" "$@"
